{
  "name": "web-security-scenario-lab",
  "version": "0.0.1",
  "private": true,
  "description": "Static, client-side-only lab generating reproducible web-page scenarios to validate the PageCheck browser detector.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node serve.mjs",
    "frameworks:install": "npm --prefix frameworks/react/v17 install && npm --prefix frameworks/react/v19 install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/alpinejs": "3.13.11",
    "@types/jquery": "^3.5.32",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "ajv": "^8.20.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-solid": "2.11.12",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "alpinejs": "3.15.12",
    "htmx.org": "2.0.10",
    "jquery": "3.7.1",
    "jquery1": "npm:jquery@1.12.4",
    "lit": "3.3.3",
    "preact": "10.29.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "solid-js": "1.9.14",
    "svelte": "5.56.4",
    "tailwindcss": "4.3.2",
    "vue": "3.5.39",
    "vue2": "npm:vue@2.7.16"
  }
}
